{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "installCommand": "npm install && npm --prefix themes/hexo-theme-stellar-1.33.1 install",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1/index.html" }
  ]
}
